# Rebuildable runtime state
system/indexes/*
!system/indexes/.gitkeep
system/runs/*
!system/runs/.gitkeep
system/leases/*
!system/leases/.gitkeep

# Local-only machine state
.local-state/
.cache/
.tmp/

# Obsidian local noise
.obsidian/cache/
.obsidian/workspace.json
.obsidian/workspace-mobile.json
.trash/

# OS noise
.DS_Store
